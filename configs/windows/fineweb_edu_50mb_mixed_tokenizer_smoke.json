{
  "status": "ready_for_smoke",
  "run": {
    "run_name": "fineweb_edu_50mb_mixed_tokenizer_smoke",
    "seed": 336,
    "output_dir": "outputs/fineweb_edu_50mb_mixed_tokenizer_smoke",
    "notes": "FineWeb-Edu public corpus smoke config only. Reuse the mixed-domain 8k tokenizer for bounded data/model/loss validation only. No tokenizer training, no model training, no checkpointing."
  },
  "hardware": {
    "target": "windows_cuda",
    "device": "cuda",
    "device_preference": "cuda_if_available_else_cpu",
    "dtype": "bf16",
    "use_tf32": false,
    "compile": false,
    "distributed": {
      "enabled": false,
      "backend": "nccl",
      "world_size": 1
    }
  },
  "tokenizer": {
    "type": "bpe",
    "tokenizer_source": "educode_bpe_mixed_domain_8k",
    "vocab_size": 8192,
    "path": "tokenizers/educode_bpe_mixed_domain_8k/tokenizer.json",
    "artifact_dir": "tokenizers/educode_bpe_mixed_domain_8k",
    "special_tokens": ["<pad>", "<bos>", "<eos>", "<unk>"],
    "pad_token_id": 0,
    "bos_token_id": 1,
    "eos_token_id": 2,
    "unk_token_id": 3
  },
  "data": {
    "dataset_name": "fineweb_edu_50mb_public",
    "train_path": "data/public_corpus/fineweb_edu_sample10bt_50mb/splits/fineweb_edu_50mb.train.jsonl",
    "val_path": "data/public_corpus/fineweb_edu_sample10bt_50mb/splits/fineweb_edu_50mb.val.jsonl",
    "data_paths": [],
    "train_split": "train",
    "val_split": "validation",
    "sequence_length": 128,
    "num_workers": 0,
    "shuffle": false,
    "streaming": false,
    "max_tokens": 65536
  },
  "model": {
    "architecture": "dense_decoder_only",
    "vocab_size": 8192,
    "context_length": 128,
    "num_layers": 4,
    "d_model": 256,
    "num_heads": 4,
    "head_dim": 64,
    "ffn_type": "swiglu",
    "d_ff": 1024,
    "norm_type": "rmsnorm",
    "position_encoding": "rope",
    "rope_theta": 10000,
    "dropout": 0.0,
    "tie_embeddings": false
  },
  "training": {
    "max_steps": 1,
    "batch_size": 4,
    "gradient_accumulation_steps": 1,
    "global_batch_tokens": 512,
    "sequence_length": 128,
    "eval_interval": 1,
    "log_interval": 1,
    "save_interval": 1,
    "grad_clip": 1.0,
    "mixed_precision": "bf16",
    "no_training": true
  },
  "optimizer": {
    "name": "adamw",
    "learning_rate": 0.0003,
    "weight_decay": 0.1,
    "betas": [0.9, 0.95],
    "eps": 1e-8
  },
  "scheduler": {
    "name": "cosine",
    "warmup_steps": 1,
    "min_lr": 3e-5,
    "max_lr": 0.0003
  },
  "checkpoint": {
    "save_dir": "checkpoints/fineweb_edu_50mb_mixed_tokenizer_smoke",
    "resume_from": null,
    "save_latest": false,
    "save_best": false,
    "keep_last_n": 1,
    "save_optimizer_state": false
  },
  "evaluation": {
    "enabled": false,
    "eval_steps": 1,
    "eval_tokens": 256,
    "metrics": ["loss"]
  },
  "generation": {
    "enabled": false,
    "prompts": ["hello world"],
    "max_new_tokens": 8,
    "temperature": 1.0,
    "top_k": 50,
    "top_p": 0.95
  },
  "profiling": {
    "enabled": false,
    "profile_steps": [1],
    "record_memory": false,
    "record_tokens_per_sec": false,
    "record_mfu": false,
    "attention_backend": "sdpa"
  },
  "logging": {
    "log_dir": "logs/fineweb_edu_50mb_mixed_tokenizer_smoke",
    "log_jsonl": false,
    "use_wandb": false,
    "wandb_project": null
  }
}
